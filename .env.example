# Databricks — patient gold layer (uniqueempi lookup)
DATABRICKS_HOST=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=

# Qdrant — ingested guideline chunks
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=CDSS_V1_MultiDisease

# OpenAI — LLM and optional embeddings
OPENAI_API_KEY=
LLM_MODEL=gpt-4o
RETRIEVAL_TAG_MODEL=

# Embeddings service (ingestion + query vectorization)
EMBEDDINGS_URL=
EMBEDDINGS_TIMEOUT_SECONDS=300

# Retrieval
TOP_K_CHUNKS=15
RERANK_ENABLED=false
RERANK_MODEL=BAAI/bge-reranker-large
RERANK_DEVICE=cpu
RERANK_BATCH_SIZE=16
RERANK_TOP_K=5

# Debug logging
LOG_RETRIEVED_CHUNKS=true
LOG_LLM_PROMPTS=true
LOG_PROMPT_MAX_CHARS=0

# Ingestion only (comma-separated PDF paths)
# INGEST_PDF_PATHS=ingestion/CKD.pdf,ingestion/Hypertension.pdf
